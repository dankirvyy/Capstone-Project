# Django core
DJANGO_SECRET_KEY=replace-with-a-strong-secret
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-service-name.onrender.com
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,https://your-service-name.onrender.com

# Database (Render/Neon PostgreSQL URL)
DATABASE_URL=postgresql://username:password@host:5432/dbname

# Email settings (optional)
EMAIL_HOST_USER=youremail@example.com
EMAIL_HOST_PASSWORD=your-email-app-password
DEFAULT_FROM_EMAIL=Mushroom Farm <youremail@example.com>
ADMIN_EMAIL=youremail@example.com
SITE_URL=https://your-service-name.onrender.com

# Local MySQL fallback (used only when DATABASE_URL is not set)
MYSQL_DB_NAME=mushroom_db
MYSQL_DB_USER=root
MYSQL_DB_PASSWORD=
MYSQL_DB_HOST=127.0.0.1
MYSQL_DB_PORT=3306
